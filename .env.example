# --- Provider selection (see common/model_factory.py and common/embedding_factory.py) ---
LLM_PROVIDER=anthropic          # anthropic (default) | openai | google | ollama
EMBEDDING_PROVIDER=voyage       # voyage (default) | openai | huggingface

# --- Anthropic (primary/reference provider) ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Other chat providers (only needed if you set LLM_PROVIDER above, or run the
#     multi-model comparison in modules/06_multiple_llms) ---
OPENAI_API_KEY=your-openai-api-key
GOOGLE_API_KEY=your-google-api-key
# Ollama needs no key — just `ollama pull llama3.1` and have the daemon running locally.

# --- Embeddings ---
VOYAGE_API_KEY=your-voyage-api-key

# --- LangSmith (module 27) ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=langchain-learning-repo
